# ══════════════════════════════════════════════════════════════
# BAJAJ PEST CONTROL — ENVIRONMENT CONFIG
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── SERVER ────────────────────────────────────────────────────
PORT=8083
NODE_ENV=production

# ── ADMIN DASHBOARD ───────────────────────────────────────────
ADMIN_PASSWORD=bajaj@admin2024
ADMIN_PHONE=+919818390810

# ── FIREBASE (Cloud Lead Storage) ─────────────────────────────
# Get from: console.firebase.google.com → Project Settings → Service Accounts
# Option A: paste entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT=

# Option B: individual fields (alternative to Option A)
FIREBASE_PROJECT_ID=bajaj-pest-control
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@bajaj-pest-control.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── SENDGRID (Email — Primary) ────────────────────────────────
# Get from: app.sendgrid.com → Settings → API Keys
# If not set, falls back to SMTP (Nodemailer) below
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@bajajpestcontrol.in

# ── SMTP / NODEMAILER (Email — Fallback) ──────────────────────
# Used when SENDGRID_API_KEY is not set
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
NOTIFY_EMAIL=bajajpeastcontol1@gmail.com
FROM_EMAIL=bajajpeastcontol1@gmail.com
FROM_NAME=Bajaj Pest Control

# ── TWILIO (WhatsApp Notifications) ───────────────────────────
# Get from: console.twilio.com → Account Info
# If not set, WhatsApp messages are silently skipped
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── GOOGLE ANALYTICS ──────────────────────────────────────────
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── COMPANY INFO ──────────────────────────────────────────────
COMPANY_PHONE=+919990146147
COMPANY_NAME=Bajaj Pest Control
WHATSAPP_NUMBER=919818390810

# ── WEBHOOK (Optional CRM / Zapier) ───────────────────────────
WEBHOOK_URL=
